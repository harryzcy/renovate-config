{
  "extends": [
    "config:best-practices",
    ":pinDependencies",
    ":disableDependencyDashboard",
    ":automergeMinor",
    "helpers:pinGitHubActionDigestsToSemver",
    ":disableRateLimiting"
  ],
  "labels": [
    "dependencies"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "labels": [
      "dependencies",
      "skip-changelog"
    ]
  },
  "automergeStrategy": "squash",
  "rebaseWhen": "behind-base-branch",
  "major": {
    "automerge": false
  },
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "minimumReleaseAge": "1 day",
      "versioning": "digest",
      "automerge": true
    },
    {
      "matchDatasources": [
        "golang-version"
      ],
      "automerge": false
    },
    {
      "matchDatasources": [
        "github-digest"
      ],
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "harryzcy/github-actions"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "minimumReleaseAge": "6 hours",
      "automerge": true
    }
  ],
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths",
    "npmDedupe"
  ]
}
